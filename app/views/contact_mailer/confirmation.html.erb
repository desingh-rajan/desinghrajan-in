<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Message Received</title>
</head>
<body style="margin:0;padding:0;background-color:#f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f1f5f9;padding:40px 16px;">
    <tr><td align="center">

      <!-- Brand header -->
      <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">
        <tr>
          <td style="padding:0 0 24px 0;text-align:center;">
            <a href="https://desinghrajan.in" style="text-decoration:none;font-size:20px;font-weight:700;color:#4f46e5;letter-spacing:-0.5px;">desinghrajan.in</a>
          </td>
        </tr>
      </table>

      <!-- Card -->
      <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e2e8f0;">

        <!-- Header stripe -->
        <tr>
          <td style="background:linear-gradient(135deg,#4f46e5 0%,#6366f1 100%);padding:32px 40px;text-align:center;">
            <!-- Checkmark icon -->
            <div style="display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;background:rgba(255,255,255,0.2);border-radius:50%;margin-bottom:16px;">
              <svg width="28" height="28" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h1 style="margin:0 0 8px 0;font-size:24px;font-weight:700;color:#ffffff;">Message received!</h1>
            <p style="margin:0;font-size:15px;color:rgba(255,255,255,0.85);">Thanks for reaching out, <%= @contact.name.split.first %>. I'll be in touch shortly.</p>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding:36px 40px 28px;">

            <p style="margin:0 0 24px 0;font-size:15px;line-height:1.7;color:#475569;">
              I've received your message and will review it shortly. You can typically expect a response within <strong style="color:#1e293b;">1&ndash;2 business days</strong>.
            </p>

            <!-- Summary card -->
            <table width="100%" cellpadding="0" cellspacing="0" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:28px;">
              <tr><td style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
                <p style="margin:0 0 2px 0;font-size:11px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#94a3b8;">Your submission</p>
              </td></tr>
              <tr><td style="padding:16px 24px;border-bottom:1px solid #f1f5f9;">
                <p style="margin:0;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.6px;color:#94a3b8;">Project type</p>
                <p style="margin:4px 0 0 0;font-size:14px;color:#1e293b;font-weight:500;"><%= @contact.project_type&.humanize || 'General inquiry' %></p>
              </td></tr>
              <tr><td style="padding:16px 24px;">
                <p style="margin:0;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.6px;color:#94a3b8;">Your message</p>
                <p style="margin:6px 0 0 0;font-size:14px;color:#374151;line-height:1.6;white-space:pre-wrap;"><%= @contact.message %></p>
              </td></tr>
            </table>

            <p style="margin:0 0 6px 0;font-size:14px;color:#64748b;">In the meantime, feel free to explore my work:</p>

            <!-- Social links -->
            <table cellpadding="0" cellspacing="0" style="margin-top:12px;">
              <tr>
                <td style="padding-right:12px;">
                  <a href="https://github.com/desingh-rajan"
                     style="display:inline-block;border:1px solid #e2e8f0;border-radius:6px;padding:8px 16px;font-size:13px;font-weight:600;color:#1e293b;text-decoration:none;">
                    GitHub
                  </a>
                </td>
                <td style="padding-right:12px;">
                  <a href="https://www.linkedin.com/in/desinghrajan/"
                     style="display:inline-block;border:1px solid #e2e8f0;border-radius:6px;padding:8px 16px;font-size:13px;font-weight:600;color:#1e293b;text-decoration:none;">
                    LinkedIn
                  </a>
                </td>
                <td>
                  <a href="https://desinghrajan.in"
                     style="display:inline-block;border:1px solid #e2e8f0;border-radius:6px;padding:8px 16px;font-size:13px;font-weight:600;color:#1e293b;text-decoration:none;">
                    Portfolio
                  </a>
                </td>
              </tr>
            </table>

            <!-- Signature -->
            <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:36px;padding-top:24px;border-top:1px solid #f1f5f9;">
              <tr>
                <td>
                  <p style="margin:0;font-size:14px;color:#64748b;">Best regards,</p>
                  <p style="margin:4px 0 2px 0;font-size:16px;font-weight:700;color:#1e293b;">Desingh Rajan</p>
                  <p style="margin:0;font-size:13px;color:#94a3b8;">Full Stack Developer &amp; Tech Consultant</p>
                </td>
              </tr>
            </table>

          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="padding:20px 40px;border-top:1px solid #f1f5f9;text-align:center;">
            <p style="margin:0;font-size:12px;color:#94a3b8;line-height:1.6;">
              You received this email because you submitted the contact form at
              <a href="https://desinghrajan.in" style="color:#94a3b8;">desinghrajan.in</a>.
              <br>If this wasn't you, you can safely ignore this email.
            </p>
          </td>
        </tr>

      </table>

      <!-- Bottom spacer -->
      <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">
        <tr><td style="height:40px;"></td></tr>
      </table>

    </td></tr>
  </table>

</body>
</html>

